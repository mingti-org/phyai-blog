---
import SiteLayout from '../layouts/SiteLayout.astro';
import { sitePath } from '../utils/site-path';
---

<SiteLayout
	title="About - PhyAI"
	description="About PhyAI, its mission, contributors, and sponsors."
	bodyClass="info-page about-page"
>
	<article class="about-simple">
		<div class="page-shell about-simple-inner reveal">
			<header>
				<h1>About PhyAI</h1>
				<p>
					PhyAI is an open-source inference framework for Physical AI. It accelerates VLA and
					world-action models on edge devices and in cloud rollout workloads while keeping model
					integration flexible.
				</p>
				<p class="about-links">
					<a href="https://github.com/MEmbodied/phyai" target="_blank" rel="noreferrer">GitHub</a>
					<a href="https://phyai.mintlify.app/" target="_blank" rel="noreferrer">Documentation</a>
				</p>
			</header>

			<section aria-labelledby="about-vision">
				<h2 id="about-vision">Our vision</h2>
				<p>
					We want to build shared inference infrastructure for embodied intelligence: fast enough
					for real-time deployment, scalable enough for reinforcement-learning rollouts, and
					dependable enough for systems that act in the physical world.
				</p>
			</section>

			<section aria-labelledby="about-contributors">
				<h2 id="about-contributors">Contributors</h2>
				<p>
					PhyAI is developed by students and faculty from Beijing University of Posts and
					Telecommunications, Peking University, and Tsinghua University.
				</p>
			</section>

			<section aria-labelledby="about-sponsors">
				<h2 id="about-sponsors">Sponsors</h2>
				<p>We are grateful to MingTi and ModelBest for supporting PhyAI.</p>
				<div class="about-sponsor-logos">
					<img src={sitePath('brand/sponsors/mingti.png')} alt="MingTi" />
					<img src={sitePath('brand/sponsors/modelbest.svg')} alt="ModelBest" />
				</div>
			</section>
		</div>
	</article>
</SiteLayout>
